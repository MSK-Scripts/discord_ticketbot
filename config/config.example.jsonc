{
  // ─── Bot Appearance ──────────────────────────────────────────────────────────
  "mainColor": "#5eb131",
  "lang": "en",                    // "de" or "en"

  // ─── Ticket Panel ────────────────────────────────────────────────────────────
  "openTicketChannelId": "CHANNEL_ID_HERE",

  // ─── Panel Settings ───────────────────────────────────────────────────────────
  "panel": {
    "interactionType": "BUTTON",     // WIP -> "BUTTON" or "SELECT_MENU"
    "logo": {
      "enabled": false,             // Set to true to show a banner image in the panel
      "file": "logo.png"            // Filename inside the assets/ folder
    },
    "banner": {
      "enabled": false,            // Set to true to show a banner image in the panel
      "file": "banner.png"         // Filename inside the assets/ folder
    }
  },

  // ─── Ticket Types ────────────────────────────────────────────────────────────
  "ticketTypes": [
    {
      "codeName": "support",
      "name": "Support",
      "description": "If you have questions or need help with our scripts",
      "emoji": "💡",
      "color": "",
      "categoryId": "CATEGORY_ID_HERE",
      "ticketNameOption": "",
      "customDescription": "A team member will get back to you as soon as possible!",
      "cantAccess": [],
      "staffRoles": [],
      "askQuestions": true,
      "questions": [
        {
          "label": "Scriptname",
          "placeholder": "Please enter the script name",
          "style": "SHORT",
          "maxLength": 50
        },
        {
          "label": "Problem Description",
          "placeholder": "Please describe the problem in detail",
          "style": "PARAGRAPH",
          "maxLength": 500
        }
      ]
    },
    {
      "codeName": "custom",
      "name": "Custom Order",
      "description": "Do you want a custom script?",
      "emoji": "⌨️",
      "color": "",
      "categoryId": "CATEGORY_ID_HERE",
      "ticketNameOption": "",
      "customDescription": "",
      "cantAccess": [],
      "staffRoles": [],
      "askQuestions": false,
      "questions": []
    }
  ],

  "ticketNameOption": "ticket-USERNAME",

  // ─── Claim Options ───────────────────────────────────────────────────────────
  "claimOption": {
    "claimButton": true,
    "nameWhenClaimed": "✔️ ticket-U_USERNAME",
    "categoryWhenClaimed": ""
  },

  // ─── Access Control ──────────────────────────────────────────────────────────
  "rolesWhoHaveAccessToTheTickets": [
    "ROLE_ID_TEAM",
    "ROLE_ID_SUPPORT"
  ],
  "rolesWhoCanNotCreateTickets": [],

  // ─── Ping on Open ────────────────────────────────────────────────────────────
  "pingRoleWhenOpened": true,
  "roleToPingWhenOpenedId": ["ROLE_ID_TEAM"],

  // ─── Logging ─────────────────────────────────────────────────────────────────
  "logs": true,
  "logsChannelId": "LOG_CHANNEL_ID_HERE",

  // ─── Close Options ───────────────────────────────────────────────────────────
  "closeOption": {
    "closeButton": true,
    "dmUser": true,
    "createTranscript": true,
    "askReason": true,
    "whoCanCloseTicket": "EVERYONE",
    "closeTicketCategoryId": ""
  },

  // ─── Rating System ───────────────────────────────────────────────────────────
  "ratingSystem": {
    "enabled": true,
    "dmUser": true,
    "ratingsChannelId": "RATINGS_CHANNEL_ID_HERE"
  },

  // ─── Staff Reminder ───────────────────────────────────────────────────────────
  "staffReminder": {
    "enabled": true,
    "afterHours": 4,
    "pingRoles": true
  },

  // ─── Auto-Close ──────────────────────────────────────────────────────────────
  "autoClose": {
    "enabled": false,
    "inactiveHours": 48,
    "warnBeforeHours": 6,
    "excludeClaimed": true
  },

  // ─── Limits ──────────────────────────────────────────────────────────────────
  "maxTicketOpened": 2,

  // ─── Bot Status ──────────────────────────────────────────────────────────────
  "status": {
    "enabled": true,
    "text": "Support Tickets",
    "type": "WATCHING",
    "url": "",
    "status": "online"
  }
}
